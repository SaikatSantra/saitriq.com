    .testimonial-slider {
      display: flex;
      gap: 1.5rem;
      will-change: transform;
    }
    .testimonial-slide {
      flex: 0 0 100%;
      min-width: 100%;
      padding-right: 1.5rem;
      display: flex;
      justify-content: center;
      align-items: stretch;
      box-sizing: border-box;
    }
    .testimonial-card {
      position: relative;
      width: min(100%, 720px);
      padding: 3rem;
      border-radius: 2.5rem;
      background: linear-gradient(180deg, rgba(8, 12, 38, 0.94), rgba(11, 16, 52, 0.98));
      border: 1px solid rgba(var(--accent-sky-rgb), 0.22);
      box-shadow: 0 48px 120px rgba(0, 0, 0, 0.32);
      overflow: hidden;
      backdrop-filter: blur(18px);
    }
    .testimonial-card::before {
      content: '';
      position: absolute;
      top: -18%;
      right: -12%;
      width: 220px;
      height: 220px;
      background: radial-gradient(circle, rgba(var(--accent-gold-rgb), 0.16), transparent 58%);
      pointer-events: none;
    }
    .testimonial-card::after {
      content: '';
      position: absolute;
      bottom: -14%;
      left: -8%;
      width: 200px;
      height: 200px;
      background: radial-gradient(circle, rgba(var(--accent-sky-rgb), 0.12), transparent 55%);
      pointer-events: none;
    }
    .testimonial-card .testimonial-copy {
      position: relative;
      z-index: 1;
    }
    .testimonial-control {
      background: rgba(var(--surface-rgb), 0.08);
      color: var(--accent);
      border-color: rgba(var(--accent-sky-rgb), 0.28);
      box-shadow: 0 18px 32px rgba(0, 0, 0, 0.18);
      transition: background-color 0.24s ease, transform 0.24s ease, border-color 0.24s ease, box-shadow 0.24s ease;
    }
    .testimonial-control:hover {
      background: rgba(var(--accent-sky-rgb), 0.18);
      transform: translateY(-2px);
      border-color: rgba(var(--accent-gold-rgb), 0.4);
      box-shadow: 0 22px 36px rgba(0, 0, 0, 0.24);
    }
    .testimonial-dot {
      width: 0.8rem;
      height: 0.8rem;
      background: rgba(var(--surface-rgb), 0.2);
      border: 1px solid rgba(var(--surface-rgb), 0.24);
      transition: transform 0.25s ease, background-color 0.25s ease, box-shadow 0.25s ease;
    }
    .testimonial-dot.active {
      background: rgba(var(--accent-cyan-rgb), 0.92);
      transform: scale(1.3);
      box-shadow: 0 0 0 6px rgba(var(--accent-cyan-rgb), 0.11);
    }

    .background-flow-canvas {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      z-index: 0;
      opacity: 0.88;
      image-rendering: auto;
      mix-blend-mode: screen;
      filter: contrast(1.24) saturate(1.18) brightness(1.04);
      pointer-events: none;
    }
    .aurora-bg::before {
      content: '';
      position: absolute;
      inset: 0;
      background-image:
        radial-gradient(circle at 20% 18%, rgba(var(--accent-gold-rgb), 0.22) 0%, transparent 18%),
        radial-gradient(circle at 76% 20%, rgba(var(--accent-violet-rgb), 0.2) 0%, transparent 16%),
        radial-gradient(circle at 48% 52%, rgba(var(--accent-cyan-rgb), 0.14) 0%, transparent 26%),
        radial-gradient(circle at 40% 18%, rgba(255,255,255,0.12) 0%, transparent 20%);
      opacity: 0.72;
      pointer-events: none;
      mix-blend-mode: screen;
      filter: blur(8px);
      z-index: 1;
    }
    .aurora-bg::after {
      content: '';
      position: absolute;
      inset: 0;
      background-image:
        linear-gradient(130deg, rgba(var(--accent-gold-rgb), 0.08) 0%, transparent 24%),
        linear-gradient(40deg, rgba(var(--accent-sky-rgb), 0.1) 0%, transparent 30%),
        radial-gradient(circle at 48% 36%, rgba(255,255,255,0.2) 0%, transparent 25%);
      opacity: 0.42;
      pointer-events: none;
      mix-blend-mode: screen;
      z-index: 1;
    }
    .aurora-wave {
      position: absolute;
      left: -12%;
      width: 124%;
      height: 18%;
      top: 22%;
      background: linear-gradient(120deg, rgba(var(--accent-gold-rgb), 0.16) 0%, rgba(var(--accent-cyan-rgb), 0.18) 35%, rgba(var(--accent-violet-rgb), 0.14) 70%, transparent 100%);
      transform: rotate(-8deg);
      filter: blur(34px);
      opacity: 0.55;
      mix-blend-mode: screen;
      pointer-events: none;
      z-index: 1;
    }
    .aurora-wave.wave-two {
      top: 46%;
      height: 16%;
      opacity: 0.48;
      background: linear-gradient(120deg, rgba(var(--accent-gold-rgb), 0.1) 0%, rgba(var(--accent-cyan-rgb), 0.16) 32%, rgba(var(--accent-violet-rgb), 0.18) 68%, transparent 100%);
      transform: rotate(6deg);
      filter: blur(28px);
    }
    .aurora-glow {
      position: absolute;
      width: 40vw;
      height: 40vw;
      background: radial-gradient(circle at center, rgba(var(--accent-gold-rgb), 0.24) 0%, rgba(var(--accent-gold-rgb), 0.08) 16%, transparent 42%);
      top: -14%;
      left: -14%;
      filter: blur(108px);
      mix-blend-mode: screen;
      opacity: 0.75;
      transform: translate3d(0,0,0);
      animation: aurora-float 24s ease-in-out infinite alternate, aurora-pulse 20s ease-in-out infinite alternate;
      z-index: 1;
    }
    .aurora-glow#aurora2 {
      width: 34vw;
      height: 34vw;
      top: 40%;
      left: 54%;
      background: radial-gradient(circle at center, rgba(var(--accent-sky-rgb), 0.18) 0%, rgba(var(--accent-violet-rgb), 0.12) 18%, transparent 44%);
      filter: blur(128px);
      opacity: 0.8;
      animation-duration: 30s, 24s;
    }

    @keyframes aurora-float {
      0% {
        transform: translate3d(0,0,0) scale(1);
      }
      50% {
        transform: translate3d(12vw,-8vh,0) scale(1.05);
      }
      100% {
        transform: translate3d(-10vw,10vh,0) scale(1.02);
      }
    }

    @keyframes aurora-pulse {
      0% {
        opacity: 0.75;
        filter: blur(108px);
      }
      50% {
        opacity: 1;
        filter: blur(140px);
      }
      100% {
        opacity: 0.80;
        filter: blur(118px);
      }
    }

    /* Noise Overlay */
    .noise-overlay {
      position: fixed;
      top: 0; left: 0; width: 100%; height: 100%;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
      opacity: 0.01;
      pointer-events: none;
      z-index: 999;
    }

    /* Bold Card Panel */
    .glass-panel {
      background: linear-gradient(180deg, rgba(6, 10, 33, 0.92), rgba(12, 20, 62, 0.88));
      border: 1px solid rgba(var(--accent-gold-rgb), 0.18);
      box-shadow: 0 40px 110px rgba(0, 0, 0, 0.28);
      backdrop-filter: none;
      overflow: hidden;
      transition: transform 0.32s ease, border-color 0.32s ease, box-shadow 0.32s ease;
    }

    .brand-logo-wrapper {
      align-items: center;
      min-height: 40px;
      gap: 1rem;
    }

    header {
      background: rgba(var(--bg-primary-rgb), 0.86);
      border-bottom: 1px solid rgba(var(--accent-gold-rgb), 0.16);
      box-shadow: 0 24px 78px rgba(0, 0, 0, 0.32);
      backdrop-filter: blur(18px);
      -webkit-backdrop-filter: blur(18px);
    }

    header nav a {
      color: var(--text-muted);
      transition: color 0.2s ease, text-shadow 0.2s ease;
    }
    header nav a:hover {
      color: var(--accent);
      text-shadow: 0 0 10px rgba(var(--accent-gold-rgb), 0.35);
    }



    #scrollHint {
      position: relative;
      letter-spacing: 0.35em;
      text-transform: uppercase;
      color: var(--text-muted);
    }

    .translateY-20 {
      transform: translateY(20px);
    }

    .glass-panel:hover {
      transform: translateY(-4px);
      border-color: rgba(var(--accent-gold-rgb), 0.28);
      box-shadow: 0 42px 120px rgba(0, 0, 0, 0.32);
    }
    .magnetic-btn {
      background: rgba(var(--accent-gold-rgb), 0.14);
      border: 1px solid rgba(var(--accent-gold-rgb), 0.22);
      color: var(--text-primary);
