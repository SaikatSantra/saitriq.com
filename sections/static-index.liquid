  <script>
    // Initialize Lucide Icons Vector Icons Replacement Engine
    lucide.createIcons();

    // Setup Lenis Smooth Scroll Mechanics
    const lenis = new Lenis({
      duration: 1.4,
      easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
      orientation: 'vertical',
      gestureOrientation: 'vertical',
      smoothWheel: true,
      smoothTouch: true,
      normalizeWheel: true,
    });

    const rootStyles = getComputedStyle(document.documentElement);
    const accentCyanRgb = rootStyles.getPropertyValue('--accent-cyan-rgb').trim();
    const accentGoldRgb = rootStyles.getPropertyValue('--accent-gold-rgb').trim();
    const accentSkyRgb = rootStyles.getPropertyValue('--accent-sky-rgb').trim();
    const bgPrimaryRgb = rootStyles.getPropertyValue('--bg-primary-rgb').trim();

    function raf(time) {
      lenis.raf(time);
      requestAnimationFrame(raf);
    }
    requestAnimationFrame(raf);

    // GSAP Core ScrollTrigger Connection Setup
    gsap.registerPlugin(ScrollTrigger);

    // Mouse Tracking Fluid Custom Cursor Control Logic
    const cursor = document.getElementById('cursor');
    document.addEventListener('mousemove', (e) => {
      gsap.to(cursor, { x: e.clientX, y: e.clientY, duration: 0.1 });
    });

    document.querySelectorAll('a, button, input, textarea').forEach(el => {
      el.addEventListener('mouseenter', () => cursor.style.transform = 'translate(-50%, -50%) scale(1.8)');
      el.addEventListener('mouseleave', () => cursor.style.transform = 'translate(-50%, -50%) scale(1)');
    });

    // Aurora Background Coordinates Distortion
    const pixelCanvas = document.getElementById('pixelCanvas');
    const pixelCtx = pixelCanvas.getContext('2d');
    let mouseX = window.innerWidth / 2;
    let mouseY = window.innerHeight / 2;
    let resizeTimeout;

    function resizePixelCanvas() {
      pixelCanvas.width = window.innerWidth;
      pixelCanvas.height = window.innerHeight;
      pixelCanvas.style.width = `${window.innerWidth}px`;
      pixelCanvas.style.height = `${window.innerHeight}px`;
    }

    function drawPixelGrid(time) {
      const width = pixelCanvas.width;
      const height = pixelCanvas.height;
      const pointerX = mouseX;
      const pointerY = mouseY;
      const influenceRadius = Math.min(width, height) * 0.22;
      const baseHue = 35;
      const centerX = width * 0.52;
      const centerY = height * 0.42;

      pixelCtx.clearRect(0, 0, width, height);
      pixelCtx.fillStyle = `rgba(${bgPrimaryRgb}, 0.92)`;
      pixelCtx.fillRect(0, 0, width, height);

      pixelCtx.lineWidth = 1.4;
      pixelCtx.globalCompositeOperation = 'screen';
      for (let layer = 0; layer < 20; layer++) {
        const t = layer / 19;
        const yBase = height * (0.13 + t * 0.7) + Math.sin(time * 0.00042 + layer * 0.95) * 18;
        pixelCtx.beginPath();
        for (let x = 0; x <= width; x += width / 180) {
          const dx = x - pointerX;
          const dy = yBase - pointerY;
          const dist = Math.sqrt(dx * dx + dy * dy);
          const influence = Math.max(0, 1 - dist / influenceRadius);
          const bend = Math.cos(dist / influenceRadius * Math.PI) * 38 * influence;
          const ripple = Math.sin((x * 0.004 + layer * 0.42 + time * 0.00092) * Math.PI) * 18;
          const px = x + Math.sin(layer * 0.33 + time * 0.0011) * 12;
          const py = yBase + ripple + bend * 0.42;
          if (x === 0) pixelCtx.moveTo(px, py);
          else pixelCtx.lineTo(px, py);
        }
        const hue = baseHue + 48 * (1 - t);
        const alpha = 0.08 + (1 - t) * 0.06;
        pixelCtx.strokeStyle = `hsla(${hue}, 92%, ${32 + t * 20}%, ${alpha})`;
        pixelCtx.stroke();
      }

      pixelCtx.globalCompositeOperation = 'lighter';
      for (let i = 0; i < 14; i++) {
        const phi = i * Math.PI * 2 / 14;
        const cx = centerX + Math.cos(phi + time * 0.00068) * (width * 0.17 + i * 2.2);
        const cy = centerY + Math.sin(phi * 1.2 + time * 0.00102) * (height * 0.11 + i * 1.6);
        const radius = 42 + Math.sin(time * 0.00125 + i) * 9;
        const gradient = pixelCtx.createRadialGradient(cx, cy, 0, cx, cy, radius);
        gradient.addColorStop(0, `rgba(${accentGoldRgb}, ${0.16 - i * 0.004})`);
        gradient.addColorStop(0.4, `rgba(${accentCyanRgb}, ${0.08 - i * 0.0022})`);
        gradient.addColorStop(1, `rgba(${bgPrimaryRgb}, 0)`);
        pixelCtx.fillStyle = gradient;
        pixelCtx.fillRect(cx - radius, cy - radius, radius * 2, radius * 2);
      }

      pixelCtx.globalCompositeOperation = 'screen';
      for (let i = 0; i < 18; i++) {
        const px = width * (0.12 + (i % 6) * 0.14) + Math.sin(time * 0.00135 + i * 1.05) * 8;
        const py = height * (0.18 + Math.floor(i / 6) * 0.14) + Math.cos(time * 0.00155 + i * 0.7) * 7;
        const dist = Math.hypot(px - pointerX, py - pointerY);
        const influence = Math.max(0, 1 - dist / (influenceRadius * 1.2));
        const radius = 1.4 + influence * 2.1;
        pixelCtx.beginPath();
        pixelCtx.fillStyle = `hsla(${baseHue + 30 - influence * 26}, 94%, ${44 + influence * 16}%, ${0.1 + influence * 0.18})`;
        pixelCtx.arc(px, py, radius, 0, Math.PI * 2);
        pixelCtx.fill();
      }

      // Add soft ambient shimmer beams
      pixelCtx.globalCompositeOperation = 'lighter';
      for (let i = 0; i < 6; i++) {
        const x = width * (0.15 + i * 0.14) + Math.sin(time * 0.00088 + i) * 16;
        const y = height * 0.76;
        const gradient = pixelCtx.createRadialGradient(x, y, 0, x, y, 64);
        gradient.addColorStop(0, `rgba(${accentGoldRgb}, 0.08)`);
        gradient.addColorStop(1, `rgba(${bgPrimaryRgb}, 0)`);
        pixelCtx.fillStyle = gradient;
        pixelCtx.fillRect(x - 64, y - 64, 128, 128);
      }

      if (pointerX >= 0 && pointerX <= width && pointerY >= 0 && pointerY <= height) {
        const gradient = pixelCtx.createRadialGradient(pointerX, pointerY, 0, pointerX, pointerY, influenceRadius * 1.1);
        gradient.addColorStop(0, `rgba(${accentGoldRgb}, 0.24)`);
        gradient.addColorStop(0.35, `rgba(${accentCyanRgb}, 0.12)`);
        gradient.addColorStop(1, `rgba(${bgPrimaryRgb}, 0)`);
        pixelCtx.fillStyle = gradient;
        pixelCtx.fillRect(pointerX - influenceRadius * 1.1, pointerY - influenceRadius * 1.1, influenceRadius * 2.2, influenceRadius * 2.2);
      }

      pixelCtx.globalCompositeOperation = 'source-over';
      requestAnimationFrame(drawPixelGrid);
    }

    function onMouseMove(e) {
      mouseX = e.clientX;
      mouseY = e.clientY;
      const xPct = mouseX / window.innerWidth;
      const yPct = mouseY / window.innerHeight;
      gsap.to('#aurora1', { x: xPct * 40, y: yPct * 40, duration: 2, ease: 'power2.out' });
      gsap.to('#aurora2', { x: -xPct * 30, y: -yPct * 30, duration: 2, ease: 'power2.out' });
    }

    window.addEventListener('mousemove', onMouseMove);
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimeout);
      resizeTimeout = setTimeout(resizePixelCanvas, 120);
    });
    resizePixelCanvas();
    requestAnimationFrame(drawPixelGrid);

    // Hero Section Reveal Stagger Elements Timeline
    window.addEventListener('DOMContentLoaded', () => {
      gsap.to('.animate-hero', {
        opacity: 1,
        y: 0,
        duration: 1,
        stagger: 0.15,
        ease: 'power3.out',
        delay: 0.2
      });
    });

    // Setup ScrollTrigger Image Reveal Mask Injections
    document.querySelectorAll('.reveal-mask').forEach(mask => {
      ScrollTrigger.create({
        trigger: mask,
        start: 'top 85%',
        onEnter: () => mask.classList.add('active')
      });
    });

    // Metrics Digital Accumulation Engine Numbers Animation
    document.querySelectorAll('.counter').forEach(counter => {
      const target = +counter.getAttribute('data-target');
      ScrollTrigger.create({
        trigger: counter,
        start: 'top 90%',
        onEnter: () => {
          let obj = { val: 0 };
          gsap.to(obj, {
            val: target,
            duration: 2,
            ease: 'power3.out',
            onUpdate: () => {
              counter.innerText = Math.floor(obj.val);
            }
          });
        }
      });
    });

    // Testimonial slider behavior
    const testimonialSlider = document.querySelector('.testimonial-slider');
    const testimonialSlides = Array.from(document.querySelectorAll('.testimonial-slide'));
    const testimonialDots = Array.from(document.querySelectorAll('.testimonial-dot'));
    let currentSlide = 0;

    function updateTestimonial(index) {
      currentSlide = Math.max(0, Math.min(index, testimonialSlides.length - 1));
      const slideOffset = testimonialSlides[currentSlide].offsetLeft;
      testimonialSlider.style.transform = `translateX(-${slideOffset}px)`;
      testimonialDots.forEach((dot, dotIndex) => {
        dot.classList.toggle('active', dotIndex === currentSlide);
        dot.classList.toggle('bg-white/30', dotIndex !== currentSlide);
      });
    }

    document.querySelectorAll('[data-action="prev"]').forEach(button => {
      button.addEventListener('click', () => updateTestimonial(currentSlide - 1));
    });
    document.querySelectorAll('[data-action="next"]').forEach(button => {
      button.addEventListener('click', () => updateTestimonial(currentSlide + 1));
    });
    testimonialDots.forEach(dot => {
      dot.addEventListener('click', () => updateTestimonial(+dot.dataset.index));
    });
    updateTestimonial(0);

    // Simple Form Submission Event Simulation Handling 
    document.getElementById('contactForm').addEventListener('submit', (e) => {
      e.preventDefault();
      alert('Transmission successful. Verification response routing initiated through secure channels.');
      e.target.reset();
    });
  </script>

