{{ 'sections-coming-soon.css' | asset_url | stylesheet_tag }}

<div class="coming-soon-wrapper" id="saitriqEngine" style="--bg-color: {{ section.settings.bg_color }}; --text-color: {{ section.settings.text_color }};">
  <canvas id="fluidCanvas"></canvas>

  <div class="viewport-frame">
    <header>
      {%- if section.settings.logo != blank -%}
        <img src="{{ section.settings.logo | image_url: width: 300 }}" alt="{{ shop.name }} Logo" class="logo-img" loading="eager">
      {%- else -%}
        <span class="logo-fallback">{{ shop.name }}</span>
      {%- endif -%}
    </header>

    <main class="main-workspace">
      <div class="hero-panel">
        {%- if section.settings.badge != blank -%}
          <div class="badge">{{ section.settings.badge }}</div>
        {%- endif -%}
        
        <h1>{{ section.settings.heading }}</h1>
        
        {%- if section.settings.tagline != blank -%}
          <p class="tagline">{{ section.settings.tagline }}</p>
        {%- endif -%}
        
        {%- if section.settings.services_list != blank -%}
          <p class="services-list">{{ section.settings.services_list }}</p>
        {%- endif -%}

        <!-- --- Interactive System Controls Block --- -->
        <div class="engine-controls">
          <span class="control-label">System Core Node:</span>
          <div class="palette-swatch-deck">
            <button class="swatch-btn active" data-theme="logo-exact" title="Saitriq Core Identity" style="--swatch-1: #2563eb; --swatch-2: #ff6a00;"></button>
            <button class="swatch-btn" data-theme="neo-quantum" title="Neo Quantum" style="--swatch-1: #3b82f6; --swatch-2: #a855f7;"></button>
            <button class="swatch-btn" data-theme="solar-eclipse" title="Solar Eclipse" style="--swatch-1: #f59e0b; --swatch-2: #10b981;"></button>
            <button class="swatch-btn" data-theme="phantom-obsidian" title="Phantom Obsidian" style="--swatch-1: #e2e8f0; --swatch-2: #2dd4bf;"></button>
            <button class="swatch-btn" data-theme="cosmic-aurora" title="Cosmic Aurora" style="--swatch-1: #06b6d4; --swatch-2: #d946ef;"></button>
            <button class="swatch-btn" data-theme="liquid-titanium" title="Liquid Titanium" style="--swatch-1: #9ca3af; --swatch-2: #a3e635;"></button>
            <button class="swatch-btn" data-theme="obsidian-rust" title="Obsidian Rust" style="--swatch-1: #f97316; --swatch-2: #ea580c;"></button>
          </div>
        </div>
      </div>

      <div class="matrix-grid">
        {%- for block in section.blocks -%}
          <div class="matrix-card{% if block.settings.full_width %} col-span-2{% endif %}" {{ block.shopify_attributes }}>
            {%- if block.settings.title != blank -%}
              <h2>{{ block.settings.title }}</h2>
            {%- endif -%}
            
            {%- if block.settings.tags != blank -%}
              <div class="stack-tags">
                {%- assign tags_arr = block.settings.tags | split: ',' -%}
                {%- assign highlights_arr = block.settings.highlighted_tags | split: ',' -%}
                
                {%- for tag in tags_arr -%}
                  {%- assign stripped_tag = tag | strip -%}
                  {%- assign is_highlight = false -%}
                  
                  {%- for h_tag in highlights_arr -%}
                    {%- assign stripped_h = h_tag | strip -%}
                    {%- if stripped_tag == stripped_h -%}
                      {%- assign is_highlight = true -%}
                    {%- endif -%}
                  {%- endfor -%}

                  <span class="tag{% if is_highlight %} highlight{% endif %}">{{ stripped_tag }}</span>
                {%- endfor -%}
              </div>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    </main>

    <footer>
      <div>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All Rights Reserved.</div>
      <div>{{ section.settings.footer_note }}</div>
    </footer>
  </div>
</div>

<script src="{{ 'sections-coming-soon.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "Coming Soon Engine Layout",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Fallback Background", "default": "#030407" },
    { "type": "color", "id": "text_color", "label": "Fallback Text", "default": "#f8fafc" },
    { "type": "image_picker", "id": "logo", "label": "Logo Image" },
    { "type": "text", "id": "badge", "label": "Badge Text", "default": "Ecosystem Deployment" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "E-Commerce<br><span>Engineered</span>" },
    { "type": "textarea", "id": "tagline", "label": "Tagline", "default": "We construct conversion-focused architecture, bespoke custom apps, and intelligence-driven tracking solutions for elite commerce networks." },
    { "type": "textarea", "id": "services_list", "label": "Services Subtext", "default": "Our Services: Shopify Store Design & Optimization, Conversion Rate Optimization (CRO), Shopify SEO, Google Ads Management..." },
    { "type": "text", "id": "footer_note", "label": "Footer Note", "default": "E-Commerce Systems Engineering Node" }
  ],
  "blocks": [
    {
      "type": "matrix_card",
      "name": "Matrix Card",
      "settings": [
        { "type": "text", "id": "title", "label": "Card Header", "default": "Core Operations" },
        { "type": "textarea", "id": "tags", "label": "Tags (Comma Separated)", "default": "Shopify Store Design, Figma to Shopify, Store Migration, Shopify Functions" },
        { "type": "textarea", "id": "highlighted_tags", "label": "Tags to Highlight", "default": "Shopify Store Design, Shopify Functions" },
        { "type": "checkbox", "id": "full_width", "label": "Span Full Width (2 Columns)", "default": false }
      ]
    }
  ],
  "presets": [
    {
      "name": "Coming Soon Engine Layout",
      "blocks": [
        { "type": "matrix_card", "settings": { "title": "Core Operations" } },
        { "type": "matrix_card", "settings": { "title": "Optimization" } }
      ]
    }
  ]
}
{% endschema %}